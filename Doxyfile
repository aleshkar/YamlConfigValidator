PROJECT_NAME           = "YamlConfigValidator"
PROJECT_BRIEF          = "Валидатор YAML-конфигураций"
OUTPUT_DIRECTORY       = docs
INPUT                  = include
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.cpp
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES
